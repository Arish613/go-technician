model Services {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  metaTitle   String?
  slug        String            @unique
  imageUrl    String?
  content     String
  location    String?
  type        String[]          @default([])
  isPublished Boolean           @default(false)
  whyChooseUs WhyChooseUsItem[]
  benefits    String[]          @default([])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  faqs        Faq[]
  subServices SubService[]
  reviews     Review[]
  cityId      String?           @db.ObjectId
  city        City?             @relation(fields: [cityId], references: [id], onDelete: SetNull)
  localityId  String?           @db.ObjectId
  locality    Locality?         @relation(fields: [localityId], references: [id], onDelete: SetNull)
}

model SubService {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  description     String
  price           Int
  discountedPrice Int?
  type            String? // "Split AC", "Window AC", or null for services without types
  imageUrl        String?
  whatIncluded    String[] @default([]) // Array of included items
  whatExcluded    String[] @default([]) // Array of excluded items
  duration        String? // e.g., "45 mins", "1-2 hours"
  isPopular       Boolean  @default(false)
  isActive        Boolean  @default(true)
  order           Int?
  serviceId       String   @db.ObjectId
  service         Services @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reviews         Review[]

  @@index([serviceId])
}

model LocationPage {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  slug        String            @unique // e.g. "ac-repair-service-in-mumbai"
  serviceSlug String // e.g. "ac-repair-service" — links to the parent service by slug
  location    String // e.g. "mumbai", "thane", "navi-mumbai"
  title       String // e.g. "AC Repair Service in Mumbai"
  metaTitle   String?
  description String
  content     String // Rich HTML content
  isPublished Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  faqs        LocationPageFaq[]
}

model LocationPageFaq {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  question       String
  answer         String
  locationPageId String       @db.ObjectId
  locationPage   LocationPage @relation(fields: [locationPageId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}


model Review {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  rating       String
  comment      String
  imageUrl     String?
  reviewer     String
  serviceId    String?     @db.ObjectId
  service      Services?   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  subServiceId String?     @db.ObjectId
  subService   SubService? @relation(fields: [subServiceId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([serviceId])
}
